<?xml version="1.0" encoding="utf-8"?>
<!-- Giữ nguyên LinearLayout cũ, chỉ thêm btnGuide ở giữa -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1209">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗺️"
        android:textSize="80sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUEST MAP"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:fontFamily="serif"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bản đồ phiêu lưu huyền bí"
        android:textSize="14sp"
        android:textColor="#8A7A5A"
        android:layout_marginBottom="48dp"/>

    <View
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:background="#FFD700"
        android:layout_marginBottom="48dp"/>

    <!-- Giữ nguyên -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="⚔️  Vào Bản Đồ"
        android:textSize="16sp"
        android:textColor="#1A1209"
        android:backgroundTint="#FFD700"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"/>

    <!-- MỚI: mở GuideActivity (dùng Navigation Graph bên trong) -->
    <Button
        android:id="@+id/btnGuide"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="📖  Hướng Dẫn"
        android:textSize="16sp"
        android:textColor="#FFD700"
        android:backgroundTint="#2D2010"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"/>

    <!-- Giữ nguyên -->
    <Button
        android:id="@+id/btnAbout"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="📜  Giới Thiệu"
        android:textSize="16sp"
        android:textColor="#8A7A5A"
        android:backgroundTint="#2D2010"
        android:stateListAnimator="@null"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0  •  Quest Map Studio"
        android:textSize="11sp"
        android:textColor="#8A7A5A"
        android:layout_marginTop="48dp"/>

</LinearLayout>